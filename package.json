{
  "name": "yodo-task",
  "version": "1.0.0",
  "description": "A local-first ToDo desktop application with system-level shortcut access and local network hosting.",
  "main": "src/main/main.js",
  "author": "Yodo Task Team <support@yodo.task>",
  "homepage": "https://github.com/yodo/task",
  "type": "commonjs",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "vite build",
    "start": "node src/main/server.js",
    "electron": "electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "package": "electron-builder"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.0",
    "cors": "^2.8.5",
    "docx": "^8.5.0",
    "express": "^4.19.2",
    "papaparse": "^5.4.1",
    "pdfkit": "^0.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^30.1.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.yodo.task",
    "productName": "Yodo Task",
    "directories": {
      "output": "dist-packaged"
    },
    "files": [
      "package.json",
      "src/main/**/*",
      "src/preload/**/*",
      "dist/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Yodo Task"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office;Utility;Todo",
      "icon": "build/icon.png",
      "maintainer": "Yodo Task Team <support@yodo.task>"
    }
  }
}
